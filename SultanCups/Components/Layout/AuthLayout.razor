@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="auth-shell">
    <div class="auth-card auth-anim @(isLeaving ? "leaving" : "")">

        <div class="auth-right">
            <div class="auth-right-inner">

                <p class="auth-hadith">
                    قال رسول الله ﷺ
                    <br />
                    «من كان حالفًا فليحلف بالله أو ليصمت»
                </p>

                <h2 class="auth-brand">مصنع أكواب السلطان</h2>

                @if (IsRegister)
                {
                    <button type="button" class="auth-ghost" @onclick="GoLogin">
                        تسجيل الدخول
                    </button>
                }
                else
                {
                    <button type="button" class="auth-ghost" @onclick="GoRegister">
                        حساب جديد
                    </button>
                }

            </div>
        </div>

        <div class="auth-left">
            @Body
        </div>

    </div>
</div>

@code {
    bool isLeaving = false;

    bool IsRegister => Nav.Uri.Contains("/register", StringComparison.OrdinalIgnoreCase);

    async Task GoLogin()
    {
        if (isLeaving) return;
        isLeaving = true;
        await Task.Delay(650);
        Nav.NavigateTo("/login", forceLoad: true);
    }

    async Task GoRegister()
    {
        if (isLeaving) return;
        isLeaving = true;
        await Task.Delay(650);
        Nav.NavigateTo("/register", forceLoad: true);
    }
}