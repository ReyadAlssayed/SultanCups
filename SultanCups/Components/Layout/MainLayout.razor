@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-shell @(IsSidebarCollapsed ? "sidebar-collapsed" : "")">

    <aside class="app-sidebar">
        <div class="sidebar-head">
            <div class="sidebar-brand">أكواب السلطان</div>

            <button type="button"
                    class="sidebar-toggle"
                    @onclick="ToggleSidebar"
                    title="إخفاء/إظهار القائمة">
                ☰
            </button>
        </div>

        <nav class="sidebar-nav">

            <!-- الرئيسية -->
            <div class="nav-group">
                <button type="button"
                        class="nav-parent"
                        @onclick='@(() => Go("/Stats"))'>
                    الرئيسية
                </button>
            </div>

            <!-- المبيعات -->
            <div class="nav-group">
                <button type="button"
                        class="nav-parent @(OpenKey == "sales" ? "active" : "")"
                        @onclick='@(() => Toggle("sales"))'>
                    المبيعات
                    <span class="chev">@(OpenKey == "sales" ? "▾" : "▸")</span>
                </button>

                <div class="nav-children @(OpenKey == "sales" ? "open" : "")">
                    <button type="button" class="nav-child" @onclick='@(() => Go("/Orders"))'>الفواتير (الطلبيات)</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/sales-payments"))'>تحصيل المبيعات</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/debts"))'>الديون</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/returns"))'>البضاعة الراجعة</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/marketers"))'>المسوقين</button>
                </div>
            </div>

            <!-- الإنتاج والمنتجات -->
            <div class="nav-group">
                <button type="button"
                        class="nav-parent @(OpenKey == "prod" ? "active" : "")"
                        @onclick='@(() => Toggle("prod"))'>
                    الإنتاج والمنتجات
                    <span class="chev">@(OpenKey == "prod" ? "▾" : "▸")</span>
                </button>

                <div class="nav-children @(OpenKey == "prod" ? "open" : "")">
                    <button type="button" class="nav-child" @onclick='@(() => Go("/Products"))'>المنتجات</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/Production"))'>الإنتاج</button>
                </div>
            </div>

            <!-- المخزون -->
            <div class="nav-group">
                <button type="button"
                        class="nav-parent @(OpenKey == "stock" ? "active" : "")"
                        @onclick='@(() => Toggle("stock"))'>
                    المخزون
                    <span class="chev">@(OpenKey == "stock" ? "▾" : "▸")</span>
                </button>

                <div class="nav-children @(OpenKey == "stock" ? "open" : "")">
                    <button type="button" class="nav-child" @onclick='@(() => Go("/raw"))'>المواد الخام</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/stores"))'>الخزنات</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/suppliers"))'>الموردين</button>
                </div>
            </div>

            <!-- المالية -->
            <div class="nav-group">
                <button type="button"
                        class="nav-parent @(OpenKey == "finance" ? "active" : "")"
                        @onclick='@(() => Toggle("finance"))'>
                    المالية
                    <span class="chev">@(OpenKey == "finance" ? "▾" : "▸")</span>
                </button>

                <div class="nav-children @(OpenKey == "finance" ? "open" : "")">
                    <button type="button" class="nav-child" @onclick='@(() => Go("/Salaries"))'>الرواتب</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/OtherExpenses"))'>المصروفات الأخرى</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/financial-events"))'>الأحداث المالية</button>
                </div>
            </div>

            <!-- الموارد البشرية -->
            <div class="nav-group">
                <button type="button"
                        class="nav-parent @(OpenKey == "hr" ? "active" : "")"
                        @onclick='@(() => Toggle("hr"))'>
                    الموارد البشرية
                    <span class="chev">@(OpenKey == "hr" ? "▾" : "▸")</span>
                </button>

                <div class="nav-children @(OpenKey == "hr" ? "open" : "")">
                    <button type="button" class="nav-child" @onclick='@(() => Go("/employees"))'>الموظفين</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/employee-events"))'>الأحداث الوظيفية</button>
                </div>
            </div>

            <!-- الإدارة -->
            <div class="nav-group">
                <button type="button"
                        class="nav-parent @(OpenKey == "admin" ? "active" : "")"
                        @onclick='@(() => Toggle("admin"))'>
                    الإدارة
                    <span class="chev">@(OpenKey == "admin" ? "▾" : "▸")</span>
                </button>

                <div class="nav-children @(OpenKey == "admin" ? "open" : "")">
                    <button type="button" class="nav-child" @onclick='@(() => Go("/Admins"))'>المسؤولين</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/Settings"))'>الإعدادات</button>
                    <button type="button" class="nav-child" @onclick='@(() => Go("/backup"))'>النسخ / الرجوع</button>
                </div>
            </div>

            <div class="nav-sep"></div>

            <button type="button" class="nav-logout" @onclick="Logout">
                تسجيل الخروج
            </button>

        </nav>
    </aside>

    <div class="app-main">
        <div class="app-card">

            <header class="app-topbar">

                <div class="top-user">
                    <span>رياض</span>
                    <span class="user-dot"></span>
                </div>

                <div class="top-search">
                    <input placeholder="ابحث..." />
                </div>

                <div class="top-logo">
                    <img src="images/ClubLogo.png" alt="Club Logo" />
                </div>

            </header>

            <main class="app-content">
                @Body
            </main>

        </div>
    </div>

</div>

@code {
    string? OpenKey = "null";

    bool IsSidebarCollapsed = false;

    void ToggleSidebar()
    {
        IsSidebarCollapsed = !IsSidebarCollapsed;
    }

    void Toggle(string key)
    {
        OpenKey = (OpenKey == key) ? null : key;
    }

    void Go(string url)
    {
        Nav.NavigateTo(url);
    }

    void Logout()
    {
        Nav.NavigateTo("/");
    }
}