@page "/CashBoxes"
@using SultanCups.Models
@using SultanCups.Services
@layout Layout.MainLayout
@inject NavigationManager Nav
@inject FinanceService FinanceService
@inject ToastService ToastService

<div class="cb-page">

    <div class="cb-topbar">
        <button class="cb-add-btn" @onclick="OpenAddDialog">إضافة خزنة</button>
        <h2 class="cb-title-center">الخزنات</h2>
        <div></div>
    </div>

    <div class="cb-card">

        <div class="cb-table-wrap">
            <table class="cb-table">

                <thead>
                    <tr>
                        <th>اسم الخزنة</th>
                        <th>الرصيد</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var c in CashBoxes)
                    {
                        <tr>
                            <td class="cb-name">@c.name</td>
                            <td>@GetBalance(c.cash_box_id)</td>
                            <td class="cb-status">
                                <span class="@(@c.is_active ? "cb-active" : "cb-inactive")">
                                    @(@c.is_active ? "نشطة" : "غير نشطة")
                                </span>
                            </td>

                            <td class="cb-actions">
                                <button class="cb-edit" @onclick="() => OpenEditDialog(c)">تعديل</button>
                                <button class="cb-delete1" @onclick="() => OpenDeleteDialog(c)">حذف</button>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>

@if (ShowAddDialog)
{
    <div class="cb-dialog-overlay">
        <div class="cb-dialog-box">

            <div class="cb-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="cb-dialog-body">
                <h3>إضافة خزنة</h3>

                <div class="cb-field">
                    <label class="cb-label">اسم الخزنة</label>
                    <input class="cb-input @(string.IsNullOrEmpty(NameError) ? "" : "is-invalid")"
                           @bind="Form.name"
                           maxlength="50"
                           @oninput="@((e) => {
                               NameError = ""; // تصفير الخطأ عند الكتابة
                               Message = "";
                               ShowActivatePrompt = false;
                               Form.name = e.Value?.ToString();
                           })" />

                @* استبدل هذا في نافذة الإضافة *@
                @if (!string.IsNullOrEmpty(NameError))
                {
                    <span class="pro-error-text">@NameError</span>
                }

                @* هذا الجزء مخصص لرسائل التكرار أو التنشيط *@
                @if (!string.IsNullOrEmpty(Message))
                {
                    <div class="prod-alert-curtain">
                        <div class="prod-error-message">@Message</div>
                        @if (ShowActivatePrompt)
                        {
                            <button type="button" @onclick="ActivateExisting" class="prod-btn-activate-link">
                                تنشيط الخزنة المؤرشفة الآن؟
                            </button>
                        }
                    </div>
                }
            </div>

                <div class="cb-dialog-actions">
                    <button type="button" class="cb-save" @onclick="Save">حفظ</button>
                    <button type="button" class="cb-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>

        </div>
    </div>
}

@if (ShowEditDialog)
{
    <div class="cb-dialog-overlay">
        <div class="cb-dialog-box">

            <div class="cb-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="cb-dialog-body">
                <h3>تعديل الخزنة</h3>

                <div class="cb-field">
                    <label class="cb-label">اسم الخزنة</label>
                    <input class="cb-input @(string.IsNullOrEmpty(NameError) && string.IsNullOrEmpty(Message) ? "" : "is-invalid")"
                           @bind="Form.name"
                           @oninput="@((e) => {
                                               Message = "";
                                               NameError = ""; // تصفير الخطأ عند البدء بالكتابة
                                               ShowActivatePrompt = false;
                                               Form.name = e.Value?.ToString();
                                           })" />

                @if (!string.IsNullOrEmpty(Message))
                {
                    <div class="prod-alert-curtain">
                        <div class="prod-error-message">@Message</div>
                        @if (ShowActivatePrompt)
                        {
                            <button type="button" @onclick="ActivateExisting" class="prod-btn-activate-link">
                                تنشيط الخزنة المؤرشفة الآن؟
                            </button>
                        }
                    </div>
                }
            </div>

            @* --- قسم رسالة الخطأ (اسم الخزنة مطلوب) --- *@
            @if (!string.IsNullOrEmpty(NameError))
            {
                <span class="pro-error-text">@NameError</span>
            }

            @* --- قسم أزرار الحالة في التعديل --- *@
            <div class="cb-field">
                <label class="cb-label">الحالة</label>
                <div class="cb-status-buttons">
                    <button type="button"
                            class="cb-status-btn @(Form.is_active ? "cb-active-selected" : "")"
                            @onclick="() => Form.is_active = true">
                        نشطة
                    </button>
                    <button type="button"
                            class="cb-status-btn @(!Form.is_active ? "cb-inactive-selected" : "")"
                            @onclick="() => Form.is_active = false">
                        غير نشطة
                    </button>
                </div>
            </div>

            <div class="cb-dialog-actions">
                <button type="button" class="cb-save" @onclick="Save">حفظ</button>
                <button type="button" class="cb-cancel" @onclick="CloseDialogs">إلغاء</button>
            </div>
        </div>

    </div>
</div>
}

@if (ShowDeleteDialog)
{
    <div class="cb-dialog-overlay">
        <div class="cb-dialog-box cb-delete-dialog-box">

            <div class="cb-dialog-top-image cb-delete-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="cb-dialog-body cb-delete-dialog-body">

                <div class="cb-delete-icon-wrap">
                    <div class="cb-delete-icon">!</div>
                </div>

                <h3 class="cb-delete-title">تأكيد إلغاء التنشيط</h3>
                <p class="cb-delete-text">هل تريد إلغاء تنشيط هذه الخزنة؟</p>

                <div class="cb-dialog-actions">
                    <button class="cb-delete" @onclick="() => Toggle(Form.cash_box_id)">تعطيل</button>
                    <button class="cb-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>

            </div>

        </div>
    </div>
}

@code {

    List<CashBox> CashBoxes = new();
    List<CashBoxBalance> Balances = new();
    CashBox Form = new();


    string Message = "";
    bool ShowActivatePrompt = false;
    CashBox? DuplicateCashBox;

    bool ShowAddDialog = false;
    bool ShowEditDialog = false;
    bool ShowDeleteDialog = false;

    string NameError = "";

    protected override async Task OnInitializedAsync()
    {
        CashBoxes = await FinanceService.GetActiveCashBoxes();
        Balances = await FinanceService.GetCashBoxBalances();
    }

    void OpenAddDialog()
    {
        Form = new CashBox
        {
            cash_box_id = 0,
            name = "",
            is_active = true
        };

        Message = "";
        NameError = "";
        ShowActivatePrompt = false;
        DuplicateCashBox = null;

        ShowAddDialog = true;
        ShowEditDialog = false;
        ShowDeleteDialog = false;
    }

    void OpenEditDialog(CashBox c)
    {
        Form = new CashBox
        {
            cash_box_id = c.cash_box_id,
            name = c.name,
            is_active = c.is_active
        };

        Message = "";
        NameError = "";
        ShowActivatePrompt = false;
        DuplicateCashBox = null;

        ShowAddDialog = false;
        ShowEditDialog = true;
        ShowDeleteDialog = false;
    }

    void OpenDeleteDialog(CashBox c)
    {
        Form = c;

        ShowAddDialog = false;
        ShowEditDialog = false;
        ShowDeleteDialog = true;
    }

    async Task Save()
    {
        Message = "";
        ShowActivatePrompt = false;

        var name = Form.name?.Trim();

        if (string.IsNullOrWhiteSpace(name))
        {
            NameError = "اسم الخزنة مطلوب";
            return;
        }

        if (name.Length < 3)
        {
            NameError = "اسم الخزنة يجب أن يكون 3 أحرف على الأقل";
            return;
        }

        if (name.Length > 50)
        {
            NameError = "اسم الخزنة لا يجب أن يتجاوز 50 حرف";
            return;
        }

        var all = await FinanceService.GetCashBoxes();

        DuplicateCashBox = all.FirstOrDefault(c =>
            c.name != null &&
            c.name.Trim().ToLower() == name.ToLower() &&
            (ShowAddDialog || c.cash_box_id != Form.cash_box_id)
        );

        if (ShowAddDialog)
        {
            if (DuplicateCashBox != null)
            {
                if (DuplicateCashBox.is_active)
                {
                    Message = "هذه الخزنة موجودة مسبقاً وهي نشطة";
                    return;
                }
                else
                {
                    Message = "الخزنة موجودة مسبقاً لكنها غير نشطة";
                    ShowActivatePrompt = true;
                    return;
                }
            }

            await FinanceService.AddCashBox(Form);
            ToastService.ShowToast("تم إضافة الخزنة بنجاح", "success");
        }
        else
        {
            if (DuplicateCashBox != null &&
            DuplicateCashBox.cash_box_id != Form.cash_box_id)
            {
                if (DuplicateCashBox.is_active)
                {
                    Message = "اسم الخزنة مستخدم بالفعل";
                    return;
                }
                else
                {
                    Message = "هذا الاسم يعود لخزنة غير نشطة، إذا كنت تريد إعادة تنشيطها توجه إلى زر إضافة خزنة";
                    ShowActivatePrompt = true;
                    return;
                }
            }

            await FinanceService.UpdateCashBox(Form);
            ToastService.ShowToast("تم تحديث الخزنة بنجاح", "success");
        }

        CashBoxes = await FinanceService.GetActiveCashBoxes();
        await RefreshBalances();
        CloseDialogs();
    }

    async Task ActivateExisting()
    {
        if (DuplicateCashBox != null)
        {
            DuplicateCashBox.is_active = true;
            await FinanceService.UpdateCashBox(DuplicateCashBox);
            ToastService.ShowToast("تم إعادة تنشيط الخزنة بنجاح", "success");

            CashBoxes = await FinanceService.GetActiveCashBoxes();
            await RefreshBalances();
            CloseDialogs();
        }
    }

    decimal GetBalance(int cashBoxId)
    {
        return Balances.FirstOrDefault(x => x.cash_box_id == cashBoxId)?.balance ?? 0;
    }

    async Task RefreshBalances()
    {
        Balances = await FinanceService.GetCashBoxBalances();
    }

    async Task Toggle(int id)
    {
        await FinanceService.ToggleCashBox(id);
        ToastService.ShowToast("تم تغيير حالة الخزنة بنجاح", "success");
        CashBoxes = await FinanceService.GetActiveCashBoxes();
        await RefreshBalances();
        CloseDialogs();
    }

    void CloseDialogs()
    {
        ShowAddDialog = false;
        ShowEditDialog = false;
        ShowDeleteDialog = false;

        Message = "";
        NameError = "";
        ShowActivatePrompt = false;
        DuplicateCashBox = null;
    }
}