@page "/Employees"
@layout Layout.MainLayout
@inject NavigationManager Nav

<div class="emp-page">

    <!-- Header -->
    <div class="emp-topbar">

        <button class="emp-add-btn">
            إضافة موظف
        </button>

        <h2 class="emp-title-center">
            الموظفين
        </h2>

        <div></div>

    </div>

    <div class="emp-card">

        <div class="emp-table-wrap">
            <table class="emp-table">

                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>رقم الهاتف</th>
                        <th>الدور</th>
                        <th>الراتب الأساسي</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var e in Employee)
                    {
                        <tr>
                            <td class="emp-name">@e.FullName</td>
                            <td class="emp-phone">@e.Phone</td>
                            <td class="emp-rank">@e.Rank</td>
                            <td class="emp-salary">@e.BaseSalary د.ل</td>

                            <td class="emp-actions">
                                <button class="emp-edit">تعديل</button>
                                <button class="emp-delete">حذف</button>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>

@code {

    List<EmployeeRow> Employee = new()
    {
        new("سالم محمد", "0912345678", "مهندس ثابت", 2500),
        new("محمود علي", "0921112233", "مهندس طلعة", 1800),
        new("خالد سالم", "0919998877", "فني", 1200),
    };

    public record EmployeeRow(string FullName, string Phone, string Rank, decimal BaseSalary);

}