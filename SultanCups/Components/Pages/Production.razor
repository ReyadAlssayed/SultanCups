@page "/production"
@layout Layout.MainLayout

<div class="pro-page">

    <div class="pro-topbar">
        <button class="pro-btn pro-btn-add" @onclick="OpenAddDialog">إضافة إنتاج</button>
        <h2 class="pro-title">الإنتاج</h2>
        <div></div>
    </div>

    <div class="pro-card">
        <div class="pro-table-wrap">
            <table class="pro-table">
                <thead>
                    <tr>
                        <th>رقم القيد</th>
                        <th>اسم المنتج</th>
                        <th>عدد الكراتين</th>
                        <th>تكلفة الكرتونة</th>
                        <th>التكلفة الكلية</th>
                        <th>تاريخ الإنتاج</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in ProductionList)
                    {
                        <tr>
                            <td class="pro-code">@p.productionId</td>
                            <td class="pro-name">@p.productName</td>
                            <td class="pro-money">@p.boxCount</td>
                            <td class="pro-money">@Fmt(p.boxCost)</td>
                            <td class="pro-money pro-total">@Fmt(p.boxCount * p.boxCost)</td>
                            <td class="pro-muted">@p.productionDate.ToString("yyyy-MM-dd")</td>

                            <td class="pro-actions-cell">
                                <button class="pro-small pro-edit" @onclick="() => OpenEditDialog(p)">تعديل</button>
                                <button class="pro-small pro-del" @onclick="() => OpenDeleteDialog(p)">حذف</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ShowAddDialog || ShowEditDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">
            <div class="pro-dialog-top-image">
                <img src="images/Background.jpg" />
            </div>

            <div class="pro-dialog-body">
                <h3>@(ShowAddDialog ? "إضافة إنتاج" : "تعديل الإنتاج")</h3>

                <div class="pro-fields-grid">
                    <div class="pro-field">
                        <label class="pro-label">المنتج</label>
                        <input class="pro-input" @bind="ProForm.productName" />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">عدد الكراتين</label>
                        <input class="pro-input" type="number" @bind="ProForm.boxCount" />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">تكلفة الكرتونة (د.ل)</label>
                        <input class="pro-input" type="number" step="0.01" @bind="ProForm.boxCost" />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">التاريخ</label>
                        <input class="pro-input" type="date" @bind="ProForm.productionDate" />
                    </div>
                </div>

                <div class="pro-dialog-actions">
                    <button type="button" class="pro-save">حفظ</button>
                    <button type="button" class="pro-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box pro-delete-dialog-box">
            <div class="pro-dialog-top-image pro-delete-top-image">
                <img src="images/Background.jpg" />
            </div>

            <div class="pro-dialog-body pro-delete-dialog-body">
                <div class="pro-delete-icon-wrap">
                    <div class="pro-delete-icon">!</div>
                </div>

                <h3 class="pro-delete-title">تأكيد الحذف</h3>
                <p class="pro-delete-text">هل تريد حذف سجل إنتاج "@ProForm.productName"؟</p>

                <div class="pro-dialog-actions">
                    <button type="button" class="pro-delete-confirm">حذف</button>
                    <button type="button" class="pro-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<ProductionRow> ProductionList = new()
    {
        new() { productionId = 1, productName = "كوب كبير 6", boxCount = 50, boxCost = 3.00m, productionDate = new DateTime(2026, 3, 7) },
        new() { productionId = 2, productName = "كوب صغير 2.5", boxCount = 40, boxCost = 2.20m, productionDate = new DateTime(2026, 3, 6) },
        new() { productionId = 3, productName = "أكواب 200ml", boxCount = 30, boxCost = 2.80m, productionDate = new DateTime(2026, 3, 5) }
    };

    bool ShowAddDialog = false;
    bool ShowEditDialog = false;
    bool ShowDeleteDialog = false;

    ProductionRow ProForm = new();

    string Fmt(decimal v) => $"{v:0.00} د.ل";

    void OpenAddDialog()
    {
        ProForm = new ProductionRow { productionDate = DateTime.Now };
        ShowAddDialog = true;
    }

    void OpenEditDialog(ProductionRow p)
    {
        ProForm = new ProductionRow
        {
            productionId = p.productionId,
            productName = p.productName,
            boxCount = p.boxCount,
            boxCost = p.boxCost,
            productionDate = p.productionDate
        };
        ShowEditDialog = true;
    }

    void OpenDeleteDialog(ProductionRow p)
    {
        ProForm = p;
        ShowDeleteDialog = true;
    }

    void CloseDialogs()
    {
        ShowAddDialog = ShowEditDialog = ShowDeleteDialog = false;
    }

    public class ProductionRow
    {
        public int productionId { get; set; }
        public string productName { get; set; } = "";
        public int boxCount { get; set; }
        public decimal boxCost { get; set; }
        public DateTime productionDate { get; set; }
    }
}