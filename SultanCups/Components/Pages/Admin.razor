@page "/Admins"
@layout Layout.MainLayout
@inject NavigationManager Nav
@inject SultanCups.Services.AdminService AdminService

<div class="ad-page">

    <div class="ad-header-center">
        <h2 class="ad-title-center">مسؤولي النظام</h2>
    </div>

    <div class="ad-card">

        <div class="ad-table-wrap">
            <table class="ad-table">

                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>اسم المستخدم</th>
                        <th>رقم الهاتف</th>
                        <th>الدور</th>
                        <th>نشط</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Admins is null)
                    {
                        <tr><td colspan="6">جاري التحميل...</td></tr>
                    }
                    else if (Admins.Count == 0)
                    {
                        <tr><td colspan="6">لا توجد بيانات</td></tr>
                    }
                    else
                    {
                        @foreach (var a in Admins)
                        {
                            <tr>
                                <td class="ad-name">@a.full_name</td>
                                <td>@a.username</td>
                                <td class="ad-phone">@a.phone</td>
                                <td class="ad-role">@a.role</td>

                                <td class="ad-active">
                                    <span class="ad-badge @(a.is_active ? "ad-on" : "ad-off")">
                                        @(a.is_active ? "نشط" : "غير نشط")
                                    </span>
                                </td>

                                <td class="ad-actions">
                                    <button class="ad-edit">تعديل</button>
                                    <button class="ad-delete">حذف</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>

@code {
    List<SultanCups.Models.Admain>? Admins;

    protected override async Task OnInitializedAsync()
    {
        Admins = await AdminService.GetAdmins();
    }
}