@page "/Purchases"
@layout Layout.MainLayout

<div class="inv-page">
    <div class="inv-topbar">
        <button class="inv-btn-add" @onclick="OpenAddDialog">إضافة فاتورة شراء</button>
        <h2 class="inv-title">سجل المشتريات الخام</h2>
        <div></div>
    </div>

    <div class="inv-card">
        <div class="inv-table-wrap">
            <table class="inv-table">
                <thead>
                    <tr>
                        <th>المادة</th>
                        <th>المورد</th>
                        <th>الكمية</th>
                        <th>سعر الوحدة</th>
                        <th>جمارك/نقل</th>
                        <th>الإجمالي</th>
                        <th>التاريخ</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in PurchaseList)
                    {
                        <tr>
                            <td class="inv-code">@p.MaterialName</td>
                            <td>@p.SupplierName</td>
                            <td>@p.Quantity</td>
                            <td class="inv-money">@p.UnitPrice.ToString("N2")</td>
                            <td class="inv-money">@((p.CustomsCost + p.TransportCost).ToString("N2"))</td>
                            <td class="inv-amount">@p.TotalCost.ToString("N2") د.ل</td>
                            <td class="inv-muted">@p.PurchaseDate.ToShortDateString()</td>
                            <td class="inv-actions-cell">
                                <button class="inv-small inv-edit" @onclick="() => OpenEditDialog(p)">تعديل</button>
                                <button class="inv-small inv-del" @onclick="() => OpenDeleteDialog(p)">حذف</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ShowAddDialog || ShowEditDialog)
{
    <div class="inv-dialog-overlay">
        <div class="inv-dialog-box">
            <div class="inv-dialog-top-image">
                <img src="images/Background.png" />
            </div>
            <div class="inv-dialog-body">
                <h3>@(ShowAddDialog ? "تسجيل مشتريات" : "تعديل بيانات الشراء")</h3>
                
                <div class="inv-fields-grid">
                    @* السطر الأول *@
                    <div class="inv-field">
                        <label class="inv-label">المادة الخام</label>
                        <select class="inv-input-dialog" @bind="PurchaseForm.RawMaterialId">
                            <option value="0">اختر مادة...</option>
                            @* هنا يتم العرض من جدول raw_materials *@
                        </select>
                    </div>
                    <div class="inv-field">
                        <label class="inv-label">المورد</label>
                        <select class="inv-input-dialog" @bind="PurchaseForm.SupplierId">
                            <option value="0">اختر مورداً...</option>
                            @* هنا يتم العرض من جدول suppliers *@
                        </select>
                    </div>

                    @* السطر الثاني *@
                    <div class="inv-field">
                        <label class="inv-label">الكمية</label>
                        <input type="number" class="inv-input-dialog" @bind="PurchaseForm.Quantity" />
                    </div>
                    <div class="inv-field">
                        <label class="inv-label">سعر الوحدة</label>
                        <input type="number" class="inv-input-dialog" @bind="PurchaseForm.UnitPrice" />
                    </div>

                    @* السطر الثالث *@
                    <div class="inv-field">
                        <label class="inv-label">مصاريف الجمرك</label>
                        <input type="number" class="inv-input-dialog" @bind="PurchaseForm.CustomsCost" />
                    </div>
                    <div class="inv-field">
                        <label class="inv-label">مصاريف النقل</label>
                        <input type="number" class="inv-input-dialog" @bind="PurchaseForm.TransportCost" />
                    </div>

                    @* السطر الرابع *@
                    <div class="inv-field">
                        <label class="inv-label">تاريخ الشراء</label>
                        <input type="date" class="inv-input-dialog" @bind="PurchaseForm.PurchaseDate" />
                    </div>
                    <div class="inv-field">
                        <label class="inv-label">الخزنة (مصدر الدفع)</label>
                        <select class="inv-input-dialog" @bind="PurchaseForm.CashBoxId">
                            @* هنا يتم العرض من جدول cash_boxes *@
                        </select>
                    </div>

                    @* السطر الخامس (عريض) *@
                    <div class="inv-field full-width">
                        <label class="inv-label">تاريخ الوصول المتوقع</label>
                        <input type="date" class="inv-input-dialog" @bind="PurchaseForm.ArrivalDate" />
                    </div>
                </div>

                <div class="inv-dialog-actions">
                    <button class="inv-save">حفظ الفاتورة</button>
                    <button class="inv-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteDialog)
{
    <div class="inv-dialog-overlay">
        <div class="inv-dialog-box">
            <div class="inv-delete-top-image">
                <div class="inv-delete-icon">!</div>
            </div>
            <div class="inv-dialog-body">
                <h3 class="inv-delete-title">تأكيد الحذف</h3>
                <p class="inv-delete-text">هل أنت متأكد من حذف سجل شراء هذه المادة؟ سيؤثر ذلك على الحسابات المالية.</p>
                <div class="inv-dialog-actions">
                    <button class="inv-delete-confirm">حذف نهائي</button>
                    <button class="inv-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    bool ShowAddDialog, ShowEditDialog, ShowDeleteDialog;
    
    // نموذج البيانات للجدول
    List<PurchaseVM> PurchaseList = new();
    
    // نموذج البيانات للفورم
    PurchaseVM PurchaseForm = new();

    protected override void OnInitialized()
    {
        // بيانات تجريبية
        PurchaseList.Add(new PurchaseVM { MaterialName = "حبيبات بلاستيك", SupplierName = "شركة النور", Quantity = 100, UnitPrice = 50, CustomsCost = 200, TransportCost = 150, PurchaseDate = DateTime.Now });
    }

    void OpenAddDialog() { PurchaseForm = new() { PurchaseDate = DateTime.Now }; ShowAddDialog = true; }
    void OpenEditDialog(PurchaseVM p) { PurchaseForm = p; ShowEditDialog = true; }
    void OpenDeleteDialog(PurchaseVM p) { PurchaseForm = p; ShowDeleteDialog = true; }
    void CloseDialogs() => ShowAddDialog = ShowEditDialog = ShowDeleteDialog = false;

    // ViewModel للعرض
    public class PurchaseVM
    {
        public int RawMaterialId { get; set; }
        public string MaterialName { get; set; } = "";
        public int SupplierId { get; set; }
        public string SupplierName { get; set; } = "";
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal CustomsCost { get; set; }
        public decimal TransportCost { get; set; }
        public DateTime PurchaseDate { get; set; }
        public DateTime? ArrivalDate { get; set; }
        public int CashBoxId { get; set; }
        
        public decimal TotalCost => (Quantity * UnitPrice) + CustomsCost + TransportCost;
    }
}