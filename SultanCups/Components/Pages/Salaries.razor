@page "/Salaries"
@layout Layout.MainLayout
@inject SultanCups.Services.FinanceService FinanceService

<div class="sal-page">


    <div class="sal-topbar">
        <h2 class="sal-title-center">الرواتب</h2>
    </div>

    <div class="sal-card">

        <div class="sal-table-wrap">
            <table class="sal-table">
                <thead>
                    <tr>
                        <th>اسم الموظف</th>
                        <th>نوع الموظف</th>
                        <th>نوع الراتب</th>
                        <th>المستحق</th>
                        <th>المدفوع</th>
                        <th>المتبقي</th>
                        <th>الحالة</th>
                        <th>الخزنة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Salarie == null)
                    {
                        <tr><td colspan="9">جاري التحميل...</td></tr>
                    }
                    else
                    {
                        @foreach (var s in Salarie)
                        {
                            <tr>
                                <td>@s.Employee.full_name</td>
                                <td>@s.Employee.rank</td>
                                <td>@s.salary_type</td>

                                <td>@s.amount</td>
                                <td>@s.paid_amount</td>
                                <td>@s.Remaining</td>

                                <td>
                                    <span class="@GetStatusClass(s.status)">
                                        @s.status
                                    </span>
                                </td>

                                <td>@s.CashBox.name</td>

                                <td class="sal-actions">
                                    <button class="sal-edit" @onclick="() => OpenEditDialog(s)">تعديل</button>

                                    <button class="sal-pay" @onclick="() => OpenPayDialog(s)">
                                        دفع
                                    </button>

                                    <button class="sal-reverse" @onclick="() => OpenReverseDialog(s)">
                                        تصحيح
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>

</div>

<!-- Dialog الدفع -->
@if (ShowPayDialog)
{
<div class="sal-dialog-overlay">
    <div class="sal-dialog-box">
        <h3>دفع راتب</h3>

        <input class="sal-input" type="number" @bind="AmountInput" placeholder="أدخل المبلغ" />

        <div class="sal-dialog-actions">
            <button class="sal-save" @onclick="ConfirmPay">تأكيد</button>
            <button class="sal-cancel" @onclick="CloseDialogs">إلغاء</button>
        </div>
    </div>
</div>


}

<!-- Dialog التصحيح -->
@if (ShowReverseDialog)
{
<div class="sal-dialog-overlay">
    <div class="sal-dialog-box">
        <h3>تصحيح راتب</h3>

        ```
        <input class="sal-input" type="number" @bind="AmountInput" placeholder="أدخل المبلغ" />

        <div class="sal-dialog-actions">
            <button class="sal-save" @onclick="ConfirmReverse">تأكيد</button>
            <button class="sal-cancel" @onclick="CloseDialogs">إلغاء</button>
        </div>
    </div>
</div>

}

<!-- Dialog التعديل (مقيد) -->
@if (ShowEditDialog)
{
<div class="sal-dialog-overlay">
    <div class="sal-dialog-box">
        <h3>تعديل (مسموح فقط الملاحظة)</h3>

        
        <input class="sal-input" @bind="SalaryForm.notes" placeholder="ملاحظة" />

        <div class="sal-dialog-actions">
            <button class="sal-save" @onclick="SaveEdit">حفظ</button>
            <button class="sal-cancel" @onclick="CloseDialogs">إلغاء</button>
        </div>
    </div>
</div>


}

@code {

List<SultanCups.Models.Salary>? Salarie;

    SultanCups.Models.Salary SalaryForm = new();

    bool ShowEditDialog, ShowPayDialog, ShowReverseDialog;

    decimal AmountInput;

    protected override async Task OnInitializedAsync()
    {
        Salarie = await FinanceService.GetSalaries();
    }

    void OpenEditDialog(SultanCups.Models.Salary s)
    {
        SalaryForm = s;
        ShowEditDialog = true;
    }

    void OpenPayDialog(SultanCups.Models.Salary s)
    {
        SalaryForm = s;
        AmountInput = 0;
        ShowPayDialog = true;
    }

    void OpenReverseDialog(SultanCups.Models.Salary s)
    {
        SalaryForm = s;
        AmountInput = 0;
        ShowReverseDialog = true;
    }

    async Task ConfirmPay()
    {
        await FinanceService.PaySalary(SalaryForm.salary_id, AmountInput);
        Salarie = await FinanceService.GetSalaries();
        CloseDialogs();
    }

    async Task ConfirmReverse()
    {
        await FinanceService.ReverseSalary(SalaryForm.salary_id, AmountInput);
        Salarie = await FinanceService.GetSalaries();
        CloseDialogs();
    }

    async Task SaveEdit()
    {
        await FinanceService.UpdateSalaryNotes(SalaryForm.salary_id, SalaryForm.notes);
        Salarie = await FinanceService.GetSalaries();
        CloseDialogs();
    }

    void CloseDialogs()
    {
        ShowEditDialog = ShowPayDialog = ShowReverseDialog = false;
    }

    string GetStatusClass(string status) => status switch
    {
        "خالص" => "sal-on",
        "خالص جزئي" => "sal-partial",
        _ => "sal-off"
    };

}
