@page "/Salaries"
@using SultanCups.Models
@layout Layout.MainLayout
@inject NavigationManager Nav
@inject SultanCups.Services.FinanceService FinanceService

<div class="sal-page">

    <div class="sal-topbar">
        <button class="sal-add-btn" @onclick="OpenAddDialog">إضافة راتب</button>
        <h2 class="sal-title-center">الرواتب</h2>
        <div></div>
    </div>

    <div class="sal-card">
        <div class="sal-table-wrap">
            <table class="sal-table">
                <thead>
                    <tr>
                        <th>الموظف</th>
                        <th>النوع</th>
                        <th>المستحق</th>
                        <th>المدفوع</th>
                        <th>المتبقي</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th>الخزنة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Salarie == null)
                    {
                        <tr><td colspan="9">جاري التحميل...</td></tr>
                    }
                    else if (Salarie.Count == 0)
                    {
                        <tr><td colspan="9">لا توجد بيانات</td></tr>
                    }
                    else
                    {
                        @foreach (var s in Salarie)
                        {
                            <tr>
                                <td>@s.Employee.full_name</td>
                                <td>@s.salary_type</td>
                                <td>@s.amount</td>
                                <td>@s.paid_amount</td>
                                <td>@s.Remaining</td>
                                <td>@s.status</td>
                                <td>@s.salary_date.ToString("yyyy-MM-dd")</td>
                                <td>@s.CashBox.name</td>

                                <td>
                                    <button @onclick="() => OpenAddPaymentDialog(s)">+ دفعة</button>
                                    <button @onclick="() => OpenReverseDialog(s)">- إلغاء</button>
                                    <button @onclick="() => OpenEditDialog(s)">تعديل</button>
                                    <button @onclick="() => OpenDeleteDialog(s)">حذف</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- إضافة راتب -->
@if (ShowAddDialog)
{
    <div class="sal-dialog-overlay">
        <div class="sal-dialog-modern">

            <!-- صورة -->
            <div class="sal-dialog-header"></div>

            <!-- المحتوى -->
            <div class="sal-dialog-body">

                <h3 class="sal-title">إضافة راتب</h3>

                <div class="sal-grid">

                    <select @bind="SalaryForm.salary_type" class="sal-input">
                        <option value="راتب أساسي">راتب أساسي</option>
                        <option value="طلعة">طلعة</option>
                    </select>

                    <select @bind="SelectedEmployeeId" class="sal-input">
                        <option value="0">اختر الموظف</option>
                        @foreach (var e in Employees)
                        {
                            <option value="@e.employee_id">@e.full_name</option>
                        }
                    </select>

                    <input class="sal-input" @bind="SalaryForm.amount" placeholder="القيمة المستحقة" />
                    <input class="sal-input" @bind="SalaryForm.paid_amount" placeholder="القيمة المدفوعة" />

                    <input class="sal-input" value="@(SalaryForm.amount - SalaryForm.paid_amount)" disabled />

                    <select class="sal-input" disabled>
                        <option>غير خالص</option>
                    </select>

                    <select @bind="selectedCashBoxId" class="sal-input">
                        <option value="0">اختر الخزنة</option>
                        @foreach (var c in CashBoxes)
                        {
                            <option value="@c.cash_box_id">@c.name</option>
                        }
                    </select>

                    <input type="date" class="sal-input" @bind="SalaryForm.salary_date" />

                    <input class="sal-input full" @bind="SalaryForm.notes" placeholder="ملاحظة" />

                </div>

                <!-- الأزرار -->
                <div class="sal-actions">
                    <button class="btn-cancel" @onclick="CloseDialogs">إلغاء</button>
                    <button class="btn-save" @onclick="SaveSalary">حفظ</button>
                </div>

            </div>
        </div>
    </div>
}
<!-- تعديل -->
@if (ShowEditDialog)
{
    <div class="sal-dialog-overlay">
        <div class="sal-dialog-modern">

            <div class="sal-dialog-header"></div>

            <div class="sal-dialog-body">

                <h3 class="sal-title">تعديل الراتب</h3>

                <div class="sal-grid">

                    <!-- نوع الراتب -->
                    <select @bind="SalaryForm.salary_type" class="sal-input">
                        <option value="راتب أساسي">راتب أساسي</option>
                        <option value="طلعة">طلعة</option>
                    </select>

                    <!-- الموظف -->
                    <select @bind="SelectedEmployeeId" class="sal-input">
                        @foreach (var e in Employees)
                        {
                            <option value="@e.employee_id">@e.full_name</option>
                        }
                    </select>

                    <!-- المستحق -->
                    <input class="sal-input"
                           @bind="SalaryForm.amount"
                           placeholder="القيمة المستحقة" />

                    <!-- المدفوع -->
                    <input class="sal-input"
                           value="@SalaryForm.paid_amount"
                           disabled />

                    <!-- المتبقي -->
                    <input class="sal-input"
                           value="@(SalaryForm.amount - SalaryForm.paid_amount)"
                           disabled />

                    <select @bind="selectedCashBoxId" class="sal-input">
                        @foreach (var c in CashBoxes)
                        {
                            <option value="@c.cash_box_id">@c.name</option>
                        }
                    </select>

                    <!-- الحالة -->
                    <select class="sal-input" disabled>
                        <option>@SalaryForm.status</option>
                    </select>

                    <!-- التاريخ -->
                    <input type="date"
                           class="sal-input"
                           @bind="SalaryForm.salary_date" />

                    <!-- الملاحظة -->
                    <input class="sal-input"
                           @bind="SalaryForm.notes"
                           placeholder="ملاحظة" />

                </div>

                <div class="sal-actions">
                    <button class="btn-cancel" @onclick="CloseDialogs">إلغاء</button>
                    <button class="btn-save" @onclick="UpdateSalaryAction">حفظ</button>
                </div>

            </div>
        </div>
    </div>
}
<!-- إضافة دفعة -->
@if (ShowAddPaymentDialog)
{
    <div class="sal-dialog-overlay">
        <div class="sal-dialog-box">
            <div class="sal-dialog-body">

                <h3>إضافة دفعة</h3>

                <input @bind="PaymentAmount" placeholder="المبلغ" />

                <button @onclick="AddPaymentAction">حفظ</button>
                <button @onclick="CloseDialogs">إلغاء</button>

            </div>
        </div>
    </div>
}

<!-- إلغاء دفعة -->
@if (ShowReverseDialog)
{
    <div class="sal-dialog-overlay">
        <div class="sal-dialog-box">
            <div class="sal-dialog-body">

                <h3>إلغاء دفعة</h3>

                <input @bind="PaymentAmount" placeholder="المبلغ" />

                <button @onclick="ReversePaymentAction">حفظ</button>
                <button @onclick="CloseDialogs">إلغاء</button>

            </div>
        </div>
    </div>
}

@if (ShowDeleteDialog)
{
    <div class="sal-dialog-overlay">
        <div class="sal-dialog-box">
            <div class="sal-dialog-body">

                <h3>تأكيد الحذف</h3>

                <p>هل أنت متأكد من حذف هذا الراتب؟</p>

                <button @onclick="DeleteSalaryAction">نعم، حذف</button>
                <button @onclick="CloseDialogs">إلغاء</button>

            </div>
        </div>
    </div>
}

@code {

    List<Salary>? Salarie;
    List<Employee> Employees = new();
    List<CashBox> CashBoxes = new();

    int selectedCashBoxId;
    bool ShowAddDialog;
    bool ShowEditDialog;
    bool ShowAddPaymentDialog;
    bool ShowReverseDialog;
    bool ShowDeleteDialog;
    bool IsEditMode = false;
    int DeleteSalaryId;

    decimal PaymentAmount;

    Salary SalaryForm = new();

    int _selectedEmployeeId;
    int SelectedEmployeeId
    {
        get => _selectedEmployeeId;
        set
        {
            _selectedEmployeeId = value;

            // 🔥 لا تعدل amount أثناء التعديل
            if (IsEditMode) return;

            var emp = Employees.FirstOrDefault(x => x.employee_id == value);
            if (emp != null)
            {
                SalaryForm.amount = emp.base_salary;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Salarie = await FinanceService.GetSalaries();
        Employees = await FinanceService.GetActiveEmployees();
        CashBoxes = await FinanceService.GetActiveCashBoxes();
    }

    void OpenAddDialog()
    {
        IsEditMode = false;

        SalaryForm = new Salary
        {
            salary_type = "راتب أساسي",
            salary_date = DateTime.UtcNow,
            paid_amount = 0
        };

        SelectedEmployeeId = 0;
        selectedCashBoxId = 0;

        ShowAddDialog = true;
    }

    void OpenDeleteDialog(Salary s)
    {
        DeleteSalaryId = s.salary_id;
        ShowDeleteDialog = true;
    }

    async Task SaveSalary()
    {
        if (SelectedEmployeeId == 0 || selectedCashBoxId == 0)
            return;

        if (SalaryForm.amount <= 0)
            return;

        if (SalaryForm.paid_amount <= 0)
            return;

        if (string.IsNullOrWhiteSpace(SalaryForm.salary_type))
            return;

        SalaryForm.employee_id = SelectedEmployeeId;
        SalaryForm.cash_box_id = selectedCashBoxId;

        SalaryForm.salary_date = DateTime.SpecifyKind(
            SalaryForm.salary_date,
            DateTimeKind.Utc);

        await FinanceService.AddSalary(SalaryForm, 20);

        Salarie = await FinanceService.GetSalaries();
        CloseDialogs();
    }

    void OpenEditDialog(Salary s)
    {
        IsEditMode = true;

        SalaryForm = new Salary
        {
            salary_id = s.salary_id,
            employee_id = s.employee_id,
            salary_type = s.salary_type,
            amount = s.amount,
            paid_amount = s.paid_amount,
            salary_date = s.salary_date,
            cash_box_id = s.cash_box_id,
            notes = s.notes,
            status = s.status
        };

        SelectedEmployeeId = s.employee_id;
        selectedCashBoxId = s.cash_box_id;

        ShowEditDialog = true;
    }

    async Task UpdateSalaryAction()
    {
        if (SelectedEmployeeId == 0)
            return;

        if (SalaryForm.amount <= 0)
            return;

        SalaryForm.employee_id = SelectedEmployeeId;
        SalaryForm.cash_box_id = selectedCashBoxId;

        await FinanceService.UpdateSalary(SalaryForm, 20);

        Salarie = await FinanceService.GetSalaries();

        CloseDialogs();
    }

    void OpenAddPaymentDialog(Salary s)
    {
        SalaryForm = s;
        PaymentAmount = 0;
        ShowAddPaymentDialog = true;
    }

    async Task AddPaymentAction()
    {
        await FinanceService.AddSalaryPayment(SalaryForm.salary_id, PaymentAmount, 20);
        Salarie = await FinanceService.GetSalaries();
        CloseDialogs();
    }

    void OpenReverseDialog(Salary s)
    {
        SalaryForm = s;
        PaymentAmount = 0;
        ShowReverseDialog = true;
    }

    async Task ReversePaymentAction()
    {
        await FinanceService.ReverseSalary(SalaryForm.salary_id, PaymentAmount, 20);
        Salarie = await FinanceService.GetSalaries();
        CloseDialogs();
    }

    async Task DeleteSalaryAction()
    {
        await FinanceService.DeleteSalary(DeleteSalaryId, 20);

        Salarie = await FinanceService.GetSalaries();

        CloseDialogs();
    }

    void CloseDialogs()
    {
        ShowAddDialog = false;
        ShowEditDialog = false;
        ShowAddPaymentDialog = false;
        ShowReverseDialog = false;
        ShowDeleteDialog = false;
    }
}