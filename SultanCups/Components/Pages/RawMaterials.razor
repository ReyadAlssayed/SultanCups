@page "/Raw"
@layout Layout.MainLayout
@inject SultanCups.Services.InventoryService InventoryService

<div class="rm-page">
    <div class="rm-topbar">
        <button class="rm-add-btn" @onclick="OpenAddDialog">إضافة مادة خام</button>
        <h2 class="rm-title-center">المواد الخام</h2>
        <div></div>
    </div>

    <div class="rm-card">
        <div class="rm-table-wrap">
            <table class="rm-table">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الحجم</th>
                        <th>وحدة القياس</th>
                        <th>تكلفة الوحدة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (RawMaterial == null)
                    {
                        <tr><td colspan="5">جاري التحميل...</td></tr>
                    }
                    else if (RawMaterial.Count == 0)
                    {
                        <tr><td colspan="5">لا توجد بيانات</td></tr>
                    }
                    else
                    {
                        @foreach (var r in RawMaterial)
                        {
                            <tr>
                                <td>@r.name</td>
                                <td>@r.size</td>
                                <td>@r.unit_of_measure</td>
                                <td>@r.unit_cost.ToString("0.00") د.ل</td>

                                <td class="rm-actions">
                                    <button class="rm-edit" @onclick="() => OpenEditDialog(r)">تعديل</button>
                                    <button class="rm-delete" @onclick="() => ToggleRawMaterial(r.raw_material_id)">
                                        @(r.is_active ? "تعطيل" : "تفعيل")
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@if (ShowAddDialog || ShowEditDialog)
{
<div class="rm-dialog-overlay">
    <div class="rm-dialog-box">
        <div class="rm-dialog-top-image"> <img src="images/Background.jpg" /> </div> <div class="rm-dialog-body">
            <h3>@(ShowAddDialog ? "إضافة مادة خام" : "تعديل المادة الخام")</h3>

            
            <div class="rm-fields-grid">
                <div class="rm-field">
                    <label>الاسم</label>
                    <input class="rm-input" @bind="RawMaterialForm.name" />
                </div>

                <div class="rm-field">
                    <label>الحجم</label>
                    <input class="rm-input" @bind="RawMaterialForm.size" />
                </div>

                <div class="rm-field">
                    <label>وحدة القياس</label>
                    <input class="rm-input" @bind="RawMaterialForm.unit_of_measure" />
                </div>

                <div class="rm-field">
                    <label>تكلفة الوحدة</label>
                    <input class="rm-input" type="number" @bind="RawMaterialForm.unit_cost" />
                </div>

                <div class="rm-field" style="grid-column: span 2;">
                    <label>ملاحظات</label>
                    <input class="rm-input" @bind="RawMaterialForm.notes" />
                </div>
            </div>

            <div class="rm-dialog-actions">
                <button class="rm-save" @onclick="SaveRawMaterial">حفظ</button>
                <button class="rm-cancel" @onclick="CloseDialogs">إلغاء</button>
            </div>
        </div>
    </div>
</div>

}

@code {

List<SultanCups.Models.RawMaterial>? RawMaterial;

    bool ShowAddDialog, ShowEditDialog;

    SultanCups.Models.RawMaterial RawMaterialForm = new();

    protected override async Task OnInitializedAsync()
    {
        RawMaterial = await InventoryService.GetActiveRawMaterials();
    }

    void OpenAddDialog()
    {
        RawMaterialForm = new SultanCups.Models.RawMaterial();
        ShowAddDialog = true;
    }

    void OpenEditDialog(SultanCups.Models.RawMaterial r)
    {
        RawMaterialForm = new SultanCups.Models.RawMaterial
        {
            raw_material_id = r.raw_material_id,
            name = r.name,
            size = r.size,
            unit_of_measure = r.unit_of_measure,
            unit_cost = r.unit_cost,
            is_active = r.is_active,
            notes = r.notes
        };

        ShowEditDialog = true;
    }

    async Task SaveRawMaterial()
    {
        if (ShowAddDialog)
        {
            await InventoryService.AddRawMaterial(RawMaterialForm);
        }
        else
        {
            await InventoryService.UpdateRawMaterial(RawMaterialForm);
        }

        RawMaterial = await InventoryService.GetActiveRawMaterials();
        CloseDialogs();
    }

    async Task ToggleRawMaterial(int id)
    {
        await InventoryService.ToggleRawMaterial(id);
        RawMaterial = await InventoryService.GetActiveRawMaterials();
    }

    void CloseDialogs()
    {
        ShowAddDialog = ShowEditDialog = false;
        RawMaterialForm = new();
    }

}
