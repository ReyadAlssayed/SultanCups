@page "/raw"
@layout Layout.MainLayout
@inject NavigationManager Nav

<div class="rm-page">

    <div class="rm-topbar">
        <button class="rm-add-btn">إضافة مادة خام</button>
        <h2 class="rm-title-center">المواد الخام</h2>
        <div></div>
    </div>

    <div class="rm-card">

        <div class="rm-table-wrap">
            <table class="rm-table">

                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الحجم</th>
                        <th>وحدة القياس</th>
                        <th>تكلفة الوحدة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var r in RawMaterial)
                    {
                        <tr>
                            <td class="rm-name">@r.Name</td>
                            <td class="rm-size">@r.Size</td>
                            <td class="rm-uom">@r.UnitOfMeasure</td>
                            <td class="rm-cost">@r.UnitCost د.ل</td>

                            <td class="rm-actions">
                                <button class="rm-edit">تعديل</button>
                                <button class="rm-delete">حذف</button>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>

@code {

    // بيانات تجريبية للتصميم فقط
    List<RawMaterialRow> RawMaterial = new()
{
    new("قاع 2.5", "66 mm", "كجم", 500),
    new("قاع 6", "62 mm", "كجم", 1200),
    new("نايلون أصفر", "60 mm", "طن", 800),
    new("غطاء شفاف", "62 mm", "كجم", 450),
    new("كرتون تغليف", "كبير", "صندوق", 300),
};

    public record RawMaterialRow(string Name, string Size, string UnitOfMeasure, decimal UnitCost);
}