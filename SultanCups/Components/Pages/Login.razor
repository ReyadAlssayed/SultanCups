@page "/"
@layout AuthLayout
@inject NavigationManager Nav

<EditForm Model="@this" OnSubmit="Submit" FormName="LoginForm">

    <div class="auth-login">

        @if (IsIdleLogout)
        {
            <div class="idle-alert-danger">
                <div class="shimmer-effect"></div> @* طبقة الحركة الداخلية *@
                <div class="alert-content">
                    <svg class="secure-icon-bold" viewBox="0 0 448 512" width="18" height="18">
                        <path d="M400 224h-24v-72C376 68.2 307.8 0 224 0S72 68.2 72 152v72H48c-26.5 0-48 21.5-48 48v192c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48V272c0-26.5-21.5-48-48-48zm-104 0H152v-72c0-39.7 32.3-72 72-72s72 32.3 72 72v72z" fill="#7f1d1d" />
                    </svg>
                    <span>تم تسجيل خروجك تلقائياً لتعزيز أمان بياناتك بعد فترة من السكون.</span>
                </div>
            </div>
        }

        <div class="auth-logo">
            <img src="images/Icon.jpg" alt="Sultan Cups Logo" />
        </div>

        <div class="taskhub-brand">
            <span class="taskhub-icon">
                <svg viewBox="0 0 40 40">
                    <circle cx="20" cy="20" r="18" fill="#2563eb" />
                    <polyline points="12,20 18,26 29,13"
                              fill="none"
                              stroke="white"
                              stroke-width="3.5"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                </svg>
            </span>
            <span class="taskhub-text">
                <span class="taskhub-task">Task</span>
                <span class="taskhub-hub">Hub</span>
            </span>
        </div>

        <h2 class="auth-title">تسجيل الدخول</h2>

        <div class="auth-fields">

            <div class="auth-field">
                <label>اسم المسؤول</label>
                <input placeholder="اكتب اسمك الكامل"
                       maxlength="40"
                       @bind="fullName"
                       disabled="@isLoading" />
            </div>

            <div class="auth-field auth-password">
                <label>كلمة المرور</label>

                <input type="@passwordType"
                       placeholder="أدخل كلمة المرور"
                       maxlength="40"
                       @bind="password"
                       disabled="@isLoading" />

                <button type="button"
                        class="auth-toggle"
                        @onclick="TogglePassword"
                        disabled="@isLoading">
                    @(passwordType == "password" ? "إظهار" : "إخفاء")
                </button>
            </div>

        </div>

        <button type="submit"
                class="auth-btn @(isLoading ? "is-busy" : "")"
                disabled="@isLoading">
            @(isLoading ? "جاري المعالجة..." : "دخول")
        </button>

    </div>
</EditForm>

@if (showDialog)
{
    <div class="auth-dialog">
        <div class="auth-dialog-box @dialogType">
            <div class="auth-dialog-icon">@dialogIcon</div>
            <p>@dialogMessage</p>
            <button type="button" @onclick="CloseDialog">حسناً</button>
        </div>
    </div>
}



@code {
    string fullName = "";
    string password = "";
    string passwordType = "password";

    bool isLoading = false;

    bool showDialog = false;
    string dialogMessage = "";
    string dialogType = "";
    string dialogIcon = "";


    bool IsIdleLogout => Nav.Uri.Contains("reason=idle");

    void TogglePassword()
        => passwordType = passwordType == "password" ? "text" : "password";

    async Task Submit()
    {
        if (isLoading) return;

        isLoading = true;
        await Task.Delay(400);

        Nav.NavigateTo("/Stats");
        isLoading = false;
    }

    void CloseDialog() => showDialog = false;
}