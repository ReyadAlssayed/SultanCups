@page "/marketers"
@layout Layout.MainLayout
@inject SultanCups.Services.SalesService SalesService

<div class="mk-page">

    
    <div class="mk-topbar">
        <button class="mk-add-btn" @onclick="OpenAddDialog">إضافة مسوق</button>
        <h2 class="mk-title-center">المسوقين</h2>
        <div></div>
    </div>

    <div class="mk-card">
        <div class="mk-table-wrap">
            <table class="mk-table">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>رقم الهاتف</th>
                        <th>العنوان</th>
                        <th>العمولة / كرتونة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (MarketerList == null)
                    {
                        <tr><td colspan="5">جاري التحميل...</td></tr>
                    }
                    else if (MarketerList.Count == 0)
                    {
                        <tr><td colspan="5">لا توجد بيانات</td></tr>
                    }
                    else
                    {
                        @foreach (var m in MarketerList)
                        {
                            <tr>
                                <td>@m.name</td>
                                <td>@m.phone</td>
                                <td>@m.address</td>
                                <td>@m.commission_per_box.ToString("0.00") د.ل</td>

                                <td class="mk-actions">
                                    <button class="mk-edit" @onclick="() => OpenEditDialog(m)">تعديل</button>

                                    <button class="mk-delete" @onclick="() => ToggleMarketer(m.marketer_id)">
                                        @(m.is_active ? "تعطيل" : "تفعيل")
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@if (ShowAddDialog || ShowEditDialog)
{
<div class="inv-dialog-overlay">
    <div class="inv-dialog-box">
        <div class="inv-dialog-top-image"> <img src="images/Background.jpg" /> </div> <div class="inv-dialog-body">
            <h3>@(ShowAddDialog ? "إضافة مسوق جديد" : "تعديل بيانات المسوق")</h3>

            
            <div class="inv-fields-grid">
                <div class="inv-field">
                    <label>اسم المسوق</label>
                    <input class="inv-input-dialog" @bind="MarketerForm.name" />
                </div>

                <div class="inv-field">
                    <label>رقم الهاتف</label>
                    <input class="inv-input-dialog" @bind="MarketerForm.phone" />
                </div>

                <div class="inv-field">
                    <label>العنوان</label>
                    <input class="inv-input-dialog" @bind="MarketerForm.address" />
                </div>

                <div class="inv-field">
                    <label>العمولة</label>
                    <input type="number" class="inv-input-dialog" @bind="MarketerForm.commission_per_box" />
                </div>

                <div class="inv-field">
                    <label>النوع</label>
                    <select class="inv-input-dialog" @bind="MarketerForm.marketer_type">
                        <option value="خارجي">خارجي</option>
                        <option value="داخلي">داخلي</option>
                    </select>
                </div>

                <div class="inv-field" style="grid-column: span 2;">
                    <label>ملاحظات</label>
                    <input class="inv-input-dialog" @bind="MarketerForm.notes" />
                </div>
            </div>

            <div class="inv-dialog-actions">
                <button class="inv-save" @onclick="SaveMarketer">حفظ</button>
                <button class="inv-cancel" @onclick="CloseDialogs">إلغاء</button>
            </div>
        </div>
    </div>
</div>

}

@code {
    List<SultanCups.Models.Marketer>? MarketerList;

bool ShowAddDialog, ShowEditDialog;

    SultanCups.Models.Marketer MarketerForm = new();

    protected override async Task OnInitializedAsync()
    {
        MarketerList = await SalesService.GetMarketers();
    }

    void OpenAddDialog()
    {
        MarketerForm = new();
        ShowAddDialog = true;
    }

    void OpenEditDialog(SultanCups.Models.Marketer m)
    {
        MarketerForm = new SultanCups.Models.Marketer
        {
            marketer_id = m.marketer_id,
            name = m.name,
            phone = m.phone,
            address = m.address,
            commission_per_box = m.commission_per_box,
            marketer_type = m.marketer_type,
            notes = m.notes,
            is_active = m.is_active
        };

        ShowEditDialog = true;
    }

    async Task SaveMarketer()
    {
        if (ShowAddDialog)
            await SalesService.AddMarketer(MarketerForm);
        else
            await SalesService.UpdateMarketer(MarketerForm);

        MarketerList = await SalesService.GetMarketers();
        CloseDialogs();
    }

    async Task ToggleMarketer(int id)
    {
        await SalesService.ToggleMarketer(id);
        MarketerList = await SalesService.GetMarketers();
    }

    void CloseDialogs()
    {
        ShowAddDialog = ShowEditDialog = false;
        MarketerForm = new();
    }

}
