@page "/marketers"
@layout Layout.MainLayout

<div class="mk-page">

    <div class="mk-topbar">
        <button class="mk-add-btn" @onclick="OpenAddDialog">إضافة مسوق</button>
        <h2 class="mk-title-center">المسوقين</h2>
        <div></div>
    </div>

    <div class="mk-card">
        <div class="mk-table-wrap">
            <table class="mk-table">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>رقم الهاتف</th>
                        <th>العنوان</th>
                        <th>العمولة / كرتونة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in MarketerList)
                    {
                        <tr>
                            <td class="mk-name">@m.Name</td>
                            <td class="mk-phone">@m.Phone</td>
                            <td class="mk-address">@m.Address</td>
                            <td class="mk-commission">@m.Commission.ToString("0.00") د.ل</td>

                            <td class="mk-actions">
                                <button class="mk-edit" @onclick="() => OpenEditDialog(m)">تعديل</button>
                                <button class="mk-delete" @onclick="() => OpenDeleteDialog(m)">حذف</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ShowAddDialog || ShowEditDialog)
{
    <div class="inv-dialog-overlay">
        <div class="inv-dialog-box">
            <div class="inv-dialog-top-image">
                <img src="images/Background.jpg" />
            </div>
            <div class="inv-dialog-body">
                <h3>@(ShowAddDialog ? "إضافة مسوق جديد" : "تعديل بيانات المسوق")</h3>
                
                <div class="inv-fields-grid">
                    <div class="inv-field">
                        <label class="inv-label">اسم المسوق</label>
                        <input class="inv-input-dialog" @bind="MarketerForm.Name" />
                    </div>
                    <div class="inv-field">
                        <label class="inv-label">رقم الهاتف</label>
                        <input class="inv-input-dialog" @bind="MarketerForm.Phone" />
                    </div>
                    <div class="inv-field">
                        <label class="inv-label">العنوان</label>
                        <input class="inv-input-dialog" @bind="MarketerForm.Address" />
                    </div>
                    <div class="inv-field">
                        <label class="inv-label">العمولة (د.ل)</label>
                        <input class="inv-input-dialog" type="number" step="0.1" @bind="MarketerForm.Commission" />
                    </div>
                </div>

                <div class="inv-dialog-actions">
                    <button type="button" class="inv-save">حفظ</button>
                    <button type="button" class="inv-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteDialog)
{
    <div class="inv-dialog-overlay">
        <div class="inv-dialog-box inv-delete-dialog-box">
            <div class="inv-dialog-top-image inv-delete-top-image">
                <img src="images/Background.jpg" />
            </div>
            <div class="inv-dialog-body inv-delete-dialog-body">
                <div class="inv-delete-icon-wrap"><div class="inv-delete-icon">!</div></div>
                <h3 class="inv-delete-title">تأكيد الحذف</h3>
                <p class="inv-delete-text">هل تريد حذف المسوق "@MarketerForm.Name" من النظام؟</p>
                <div class="inv-dialog-actions">
                    <button type="button" class="inv-delete-confirm">حذف</button>
                    <button type="button" class="inv-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<MarketerModel> MarketerList = new()
    {
        new() { Name = "محمد سالم", Phone = "0912345678", Address = "زليتن", Commission = 2m },
        new() { Name = "علي مفتاح", Phone = "0921112233", Address = "مصراتة", Commission = 3m }
    };

    bool ShowAddDialog, ShowEditDialog, ShowDeleteDialog;
    MarketerModel MarketerForm = new();

    void OpenAddDialog() { MarketerForm = new MarketerModel(); ShowAddDialog = true; }
    void OpenEditDialog(MarketerModel m)
    {
        MarketerForm = new MarketerModel { Name = m.Name, Phone = m.Phone, Address = m.Address, Commission = m.Commission };
        ShowEditDialog = true;
    }
    void OpenDeleteDialog(MarketerModel m) { MarketerForm = m; ShowDeleteDialog = true; }
    void CloseDialogs() => ShowAddDialog = ShowEditDialog = ShowDeleteDialog = false;

    public class MarketerModel
    {
        public string Name { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Address { get; set; } = "";
        public decimal Commission { get; set; }
    }
}