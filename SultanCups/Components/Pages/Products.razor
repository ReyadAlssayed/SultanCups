@page "/Products"
@layout Layout.MainLayout
@inject SultanCups.Services.InventoryService InventoryService

<div class="prod-page">

    <div class="prod-topbar">
        <button class="prod-btn prod-btn-add" @onclick="OpenAddDialog">إضافة منتج</button>
        <h2 class="prod-title">المنتجات</h2>
        <div></div>
    </div>

    <div class="prod-card">
        <div class="prod-table-wrap">
            <table class="prod-table">
                <thead>
                    <tr>
                        <th>رقم القيد</th>
                        <th>اسم المنتج</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ProductList is null)
                    {
                        <tr><td colspan="3">جاري التحميل...</td></tr>
                    }
                    else if (ProductList.Count == 0)
                    {
                        <tr><td colspan="3">لا توجد بيانات</td></tr>
                    }
                    else
                    {
                        @foreach (var p in ProductList)
                        {
                            <tr>
                                <td class="prod-code">@p.product_id</td>
                                <td class="prod-name">@p.name</td>

                                <td class="prod-actions-cell">
                                    <button class="prod-small prod-edit" @onclick="() => OpenEditDialog(p)">تعديل</button>
                                    <button class="prod-small prod-del" @onclick="() => OpenDeleteDialog(p)">حذف</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ShowAddDialog || ShowEditDialog)
{
    <div class="prod-dialog-overlay">
        <div class="prod-dialog-box">
            <div class="prod-dialog-top-image">
                <img src="images/Background.jpg" />
            </div>

            <div class="prod-dialog-body">
                <h3>@(ShowAddDialog ? "إضافة منتج جديد" : "تعديل المنتج")</h3>

                <div class="prod-field">
                    <label class="prod-label">اسم المنتج</label>
                    <input class="prod-input" @bind="ProductForm.name" />
                </div>

                <div class="prod-dialog-actions">
                    <button type="button" class="prod-save" @onclick="SaveProduct">حفظ</button>
                    <button type="button" class="prod-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteDialog)
{
    <div class="prod-dialog-overlay">
        <div class="prod-dialog-box prod-delete-dialog-box">
            <div class="prod-dialog-top-image prod-delete-top-image">
                <img src="images/Background.jpg" />
            </div>

            <div class="prod-dialog-body prod-delete-dialog-body">
                <div class="prod-delete-icon-wrap">
                    <div class="prod-delete-icon">!</div>
                </div>

                <h3 class="prod-delete-title">تأكيد الحذف</h3>
                <p class="prod-delete-text">هل تريد حذف المنتج "@ProductForm.name" نهائيًا؟</p>

                <div class="prod-dialog-actions">
                    <button type="button" class="prod-delete-confirm" @onclick="ConfirmDelete">حذف</button>
                    <button type="button" class="prod-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@code {

    List<SultanCups.Models.Product>? ProductList;

    bool ShowAddDialog = false;
    bool ShowEditDialog = false;
    bool ShowDeleteDialog = false;

    SultanCups.Models.Product ProductForm = new();

    protected override async Task OnInitializedAsync()
    {
        ProductList = await InventoryService.GetProducts();
    }

    void OpenAddDialog()
    {
        CloseDialogs();
        ProductForm = new SultanCups.Models.Product();
        ShowAddDialog = true;
    }

    void OpenEditDialog(SultanCups.Models.Product p)
    {
        CloseDialogs();

        ProductForm = new SultanCups.Models.Product
        {
            product_id = p.product_id,
            name = p.name
        };

        ShowEditDialog = true;
    }

    void OpenDeleteDialog(SultanCups.Models.Product p)
    {
        CloseDialogs();

        ProductForm = new SultanCups.Models.Product
        {
            product_id = p.product_id,
            name = p.name
        };

        ShowDeleteDialog = true;
    }

    async Task SaveProduct()
    {
        if (ShowAddDialog)
        {
            await InventoryService.AddProduct(ProductForm);
        }
        else
        {
            await InventoryService.UpdateProduct(ProductForm);
        }

        ProductList = await InventoryService.GetProducts();
        CloseDialogs();
    }

    async Task ConfirmDelete()
    {
        await InventoryService.DeleteProduct(ProductForm.product_id);
        ProductList = await InventoryService.GetProducts();
        CloseDialogs();
    }

    void CloseDialogs()
    {
        ShowAddDialog = false;
        ShowEditDialog = false;
        ShowDeleteDialog = false;
        ProductForm = new SultanCups.Models.Product();
    }
}