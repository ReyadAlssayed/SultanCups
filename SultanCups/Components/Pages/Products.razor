@page "/Products"
@using System.Text.RegularExpressions
@layout Layout.MainLayout
@inject SultanCups.Services.InventoryService InventoryService


<div class="prod-page">

    @if (!string.IsNullOrEmpty(ToastMessage))
    {
        <div class="prod-toast-container">
            <div class="prod-toast @ToastClass">
                @ToastMessage
            </div>
        </div>
    }
    <div class="prod-topbar">
        <button class="prod-btn prod-btn-add" @onclick="OpenAddDialog">إضافة منتج</button>
        <h2 class="prod-title">المنتجات</h2>
        <div></div>
    </div>

    <div class="prod-card">
        <div class="prod-table-wrap">
            <table class="prod-table">
                <thead>
                    <tr>
                        <th>اسم المنتج</th>
                        <th style="text-align:center">الحالة</th>
                        <th style="text-align:center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ProductList is null)
                    {
                        <tr><td colspan="3" style="text-align:center">جاري التحميل...</td></tr>
                    }
                    else if (ProductList.Count == 0)
                    {
                        <tr><td colspan="3" style="text-align:center">لا توجد بيانات</td></tr>
                    }
                    else
                    {
                        @foreach (var p in ProductList)
                        {
                            <tr>
                                <td class="prod-name">@p.name</td>
                            
                                <td style="text-align:center">
                                    @if (p.is_active)
                                    {
                                        <span class="status-badge active">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge inactive">غير نشط</span>
                                    }
                                </td>

                                <td class="prod-actions-cell">
                                    <button class="prod-small prod-edit" @onclick="() => OpenEditDialog(p)">تعديل</button>
                                    <button class="prod-small prod-del" @onclick="() => OpenDeleteDialog(p)">
                                        @(p.is_active ? "حذف" : "تنشيط")
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ShowAddDialog || ShowEditDialog)
{
    <div class="prod-dialog-overlay">
        <div class="prod-dialog-box">
            <div class="prod-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="prod-dialog-body">
                <h3>@(ShowAddDialog ? "إضافة منتج جديد" : "تعديل المنتج")</h3>

                @* 1. حقل اسم المنتج *@
                <div class="prod-field">
                    <label class="prod-label">اسم المنتج</label>
                    <input class="prod-input @(string.IsNullOrWhiteSpace(Message) ? "" : "is-invalid")"
                           @bind="ProductForm.name" maxlength="100" />

                    @if (!string.IsNullOrWhiteSpace(Message))
                    {
                        @* حاوية التنبيه التي ستفتح مثل الستارة *@
                        <div class="prod-alert-curtain">
                            <div class="prod-error-message">@Message</div>
        
                            @if (ShowActivatePrompt)
                            {
                                <button type="button" @onclick="ActivateExisting" class="prod-btn-activate-link">
                                    تنشيط المنتج الآن
                                </button>
                            }
                        </div>
                    }
                </div>

                @* 2. حقل حالة المنتج: يظهر فقط في شاشة التعديل *@
                @if (ShowEditDialog)
                {
                    <div class="prod-status-container">
                        <label class="prod-label">حالة المنتج</label>
                        <div class="prod-status-buttons">
                            <button type="button"
                                    class="prod-status-btn @(ProductForm.is_active ? "prod-active-selected" : "")"
                                    @onclick="() => ProductForm.is_active = true">
                                نشط
                            </button>

                            <button type="button"
                                    class="prod-status-btn @(!ProductForm.is_active ? "prod-inactive-selected" : "")"
                                    @onclick="() => ProductForm.is_active = false">
                                معطل
                            </button>
                        </div>
                    </div>
                }

                <div class="prod-dialog-actions">
                    <button type="button" class="prod-save" @onclick="SaveProduct">حفظ</button>
                    <button type="button" class="prod-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteDialog)
{
    <div class="prod-dialog-overlay">
        <div class="prod-dialog-box prod-delete-dialog-box">
            <div class="prod-dialog-top-image prod-delete-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="prod-dialog-body prod-delete-dialog-body">
                <div class="prod-delete-icon-wrap">
                    <div class="prod-delete-icon">!</div>
                </div>

                <h3 class="prod-delete-title">تأكيد الحذف <span>(إلغاء التنشيط)</span></h3>
                <p class="prod-delete-text">هل تريد إلغاء تنشيط المنتج "@ProductForm.name"؟</p>

                <div class="prod-dialog-actions">
                    <button type="button" class="prod-delete-confirm" @onclick="ConfirmDelete">حذف</button>
                    <button type="button" class="prod-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@code {

    List<SultanCups.Models.Product>? ProductList;

    bool ShowAddDialog = false;
    bool ShowEditDialog = false;
    bool ShowDeleteDialog = false;
    bool ShowInactive = false;

    string Message = string.Empty;
    string ToastMessage = string.Empty;
    string ToastClass = "success"; // أضفنا هذا المتغير لتحديد اللون

    bool ShowActivatePrompt = false; // أضف هذا المتغير في الأعلى مع المتغيرات
    SultanCups.Models.Product? DuplicateProduct; // لتخزين المنتج الذي وجدناه


    SultanCups.Models.Product ProductForm = new();

    protected override async Task OnInitializedAsync()
    {
        ProductList = await InventoryService.GetProducts();
    }

    void OpenAddDialog()
    {
        CloseDialogs();
        Message = string.Empty;
        ProductForm = new SultanCups.Models.Product { is_active = true }; // تأكد من إضافة is_active هنا
        ShowAddDialog = true;
    }

    void OpenEditDialog(SultanCups.Models.Product p)
    {
        CloseDialogs();
        Message = string.Empty;

        ProductForm = new SultanCups.Models.Product
        {
            product_id = p.product_id,
            name = p.name,
            is_active = p.is_active // السطر المضاف
        };

        ShowEditDialog = true;
    }

    void OpenDeleteDialog(SultanCups.Models.Product p)
    {
        CloseDialogs();
        Message = string.Empty;

        ProductForm = new SultanCups.Models.Product
        {
            product_id = p.product_id,
            name = p.name
        };

        ShowDeleteDialog = true;
    }


    async Task SaveProduct()
    {
        Message = string.Empty;
        ShowActivatePrompt = false;
        var name = ProductForm.name?.Trim();

        if (string.IsNullOrWhiteSpace(name)) { Message = "اسم المنتج مطلوب"; return; }
    
        // فحص التكرار الشامل
        var allProducts = await InventoryService.GetAllProducts();
        DuplicateProduct = allProducts.FirstOrDefault(p => p.name?.Trim().ToLower() == name.ToLower());

        if (ShowAddDialog)
        {
            if (DuplicateProduct != null)
            {
                if (DuplicateProduct.is_active)
                {
                    Message = "هذا المنتج موجود مسبقاً وهو نشط.";
                    return;
                }
                else
                {
                    // المنتج موجود لكنه غير نشط
                    Message = $"المنتج '{name}' موجود مسبقاً في الأرشيف (غير نشط).";
                    ShowActivatePrompt = true; // سنظهر زر "تنشيط الآن" في الواجهة
                    return;
                }
            }
            ProductForm.is_active = true;
            await InventoryService.AddProduct(ProductForm);
        }
        else // حالة التعديل Edit
        {
            if (DuplicateProduct != null && DuplicateProduct.product_id != ProductForm.product_id)
            {
                // الرسالة التي طلبتها
                Message = "هذا الاسم موجود بالفعل؛ إذا كنت تريد تفعيله، أعد كتابته في واجهة (إضافة منتج) بنفس الاسم ثم اضغط تنشيط.";
                return;
            }
            await InventoryService.UpdateProduct(ProductForm);
        }

        await RefreshData();
        ShowToast(ShowAddDialog ? "تمت الإضافة بنجاح" : "تم التعديل بنجاح");
        CloseDialogs();
    }

    // دالة جديدة لتنشيط المنتج مباشرة من الرسالة
    async Task ActivateExisting()
    {
        if (DuplicateProduct != null)
        {
            DuplicateProduct.is_active = true;
            await InventoryService.UpdateProduct(DuplicateProduct);
            await RefreshData();
            ShowToast("تم إعادة تنشيط المنتج بنجاح");
            CloseDialogs();
        }
    }

    void ShowToast(string msg, string type = "success")
    {
        ToastMessage = msg;
        ToastClass = type; // تحديد الكلاس بناءً على النوع
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ =>
        {
            ToastMessage = string.Empty;
            InvokeAsync(StateHasChanged);
        });
    }

    void CloseDialogs()
    {
        ShowAddDialog = false;
        ShowEditDialog = false;
        ShowDeleteDialog = false;
        Message = string.Empty;
        ProductForm = new SultanCups.Models.Product();
    }

    async Task ToggleInactive()
    {
        ShowInactive = !ShowInactive;

        if (ShowInactive)
            ProductList = await InventoryService.GetAllProducts(); // الكل
        else
            ProductList = await InventoryService.GetProducts(); // النشط فقط
    }

    async Task RefreshData()
    {
        ProductList = await InventoryService.GetProducts();
        StateHasChanged();
    }

    async Task ConfirmDelete()
    {
        await InventoryService.DeleteProduct(ProductForm.product_id);
        await RefreshData();
        
        // التعديل هنا: تغيير نص الرسالة ليكون أكثر دقة
        ShowToast("تم إلغاء تنشيط المنتج بنجاح", "error");
        
        CloseDialogs();
    }
}